
@using Syncfusion.EJ2
@using Syncfusion.EJ2.Charts

@section ControlsSection{
    <div class="control-section" align="center">
        @Html.EJS().Sankey("sankey-orientation").Width("90%").Height("650px").Background("transparent").Orientation(Syncfusion.EJ2.Charts.Orientation.Vertical).Title("U.S. Greenhouse Gas Emissions by Economic Sector (2022)").SubTitle("Source: EPA 2022 GHG Inventory").Margin(margin => margin.Left(20).Right(20).Top(20).Bottom(20)
        ).Border(border => border.Width(0).Color("#E0E0E0")).NodeStyle(nodeStyle => nodeStyle.Width(30).Padding(8).Opacity(1)
        ).LinkStyle(linkStyle => linkStyle.Opacity(0.5).Curvature(0.55).ColorType(Syncfusion.EJ2.Charts.ColorType.Source)
        ).LabelSettings(label => label.Visible(true)).Tooltip(tooltip => tooltip.Enable(true)
        .NodeTemplate("${name}: ${value} MMT CO₂e")
        .LinkTemplate("${start.name}: ${start.out} MMT CO₂e → ${target.name}: ${target.in} MMT CO₂e")).LegendSettings(legend => legend.Visible(false).Position(Syncfusion.EJ2.Charts.LegendPosition.Right)
        ).Nodes((List<SankeyNode>)ViewData["SankeyNodes"]).Links((List<SankeyLink>)ViewData["SankeyLinks"]).Load("load").Render()
    </div>

    <style>
        #control-container {
            padding: 0 !important;
        }
    </style>

    <script src="~/Scripts/sankey/theme-color.js"></script>
    <script>
        function load(args) {
            if (typeof loadSankeyChartTheme === 'function') {
                loadSankeyChartTheme(args);
            }

            if (args && args.chart) {
                var isMobile = ej.base.Browser.isDevice;
                args.chart.width = isMobile ? "100%" : "90%";
                args.chart.height = "650";
                if (isMobile) {
                    args.chart.labelSettings = args.chart.labelSettings || {};
                    args.chart.legendSettings = args.chart.legendSettings || {};
                    args.chart.labelSettings.visible = false;
                    args.chart.legendSettings.visible = false;
                    args.chart.title = "U.S. Greenhouse Gas Emissions";
                    args.chart.tooltip.linkTemplate = isMobile ? '${start.name}: ${start.out} MMT CO₂e → <br/> ${target.name}: ${target.in} MMT CO₂e' : '${start.name}: ${start.out} MMT CO₂e → ${target.name}: ${target.in} MMT CO₂e';
                } else {
                    args.chart.title = "U.S. Greenhouse Gas Emissions by Economic Sector (2022)";
                    args.chart.labelSettings.visible = true;
                    args.chart.legendSettings.visible = true;
                    args.chart.legendSettings.position = "Right";
                }
            }
        }
    </script>
}

@section ActionDescription{
    <p>
        Explore U.S. greenhouse gas emissions by economic sector (2022) in a vertical Sankey chart measured in MMT CO₂e (million metric tons of CO₂ equivalent). Trace top‑to‑bottom flows from sectors—Transportation, Industry, Commercial, Residential, and Agriculture—through direct and indirect electricity use to total atmospheric emissions.
    </p>
}
@section Description{
    <p>
        This vertical Sankey chart visualizes U.S. GHG emissions in MMT CO₂e, showing how sector sources split into road, aviation, direct emissions, and indirect electricity use before reaching total atmospheric emissions.
        Hover or tap nodes and links to see precise MMT CO₂e values and relationships.
    </p>
    <p><strong>Key features:</strong></p>
    <ul>
        <li>Break down emissions by sector and pathway (direct vs. indirect electricity)</li>
        <li>Follow top‑to‑bottom flows to the atmosphere for clear attribution</li>
        <li>Interactive tooltips reveal exact MMT CO₂e values per node and link</li>
    </ul>
}
@section Meta{
    <meta name="description" content="ASP.NET MVC vertical Sankey diagram of U.S. greenhouse gas emissions by sector (2022), showing direct and indirect electricity pathways to total atmospheric emissions.">
}
@section Title{
    <title>ASP.NET MVC Vertical Sankey - U.S. GHG Emissions (2022)</title>
}
@section Header{
    <h1 class='sb-sample-text'>Vertical Sankey: U.S. GHG Emissions (2022)</h1>
}
