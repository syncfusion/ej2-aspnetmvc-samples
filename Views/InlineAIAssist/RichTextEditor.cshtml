@using Syncfusion.EJ2
@using Syncfusion.EJ2.InteractiveChat

@{
    var quickToolbarItems = new object[]
    {
        new { prefixIcon = "e-icons e-ai-chat", tooltipText = "AI Assistant" },
        "Bold", "Italic", "Underline", "StrikeThrough", "Fontcolor", "BackgroundColor", "|", "Unorderedlist", "Orderedlist"
    };

    var commandsData = new object[]
    {
        new { label="Improve Content", prompt="Improve the clarity, coherence, and overall quality of the following content:", iconCss= "e-icons e-magic-wand" },
        new { label="Elaborate", prompt="Expand on the following content with more detail and explanation:", iconCss= "e-icons e-shorten" },
        new { label="Simplify", prompt="Simplify the language and make the following content easier to understand:", iconCss= "e-icons e-elaborate" },
        new { label="Summarize", prompt="Summarize the following content in a concise and clear way:", iconCss= "e-icons e-collapse-2" },
        new { label="Check Grammar &amp; Spelling", prompt="Check the following content for grammar and spelling mistakes, and correct them:", iconCss= "e-icons e-grammar-check" }
    };
}

@section ControlsSection {
    <div class="control-section">
        <div class="rte-integration-container">
            @Html.EJS().RichTextEditor("rteEditor").QuickToolbarSettings(quickToolbar => quickToolbar.Text(quickToolbarItems)).Created("created").ToolbarClick("toolbarClick").Value("<p><strong>Introduction</strong></p><p>Technology has transformed the way we communicate and collaborate in both personal and professional settings. Digital tools enable instant connectivity across global distances, breaking down traditional barriers and creating new opportunities for innovation and growth.</p><p><strong>Key Benefits</strong></p><p>The integration of artificial intelligence into everyday applications is revolutionizing user experiences. From smart assistants to predictive analytics, AI-powered features help users accomplish tasks more efficiently while providing personalized recommendations based on individual preferences and behavior patterns.</p><p><strong>Implementation Approach</strong></p><p>When adopting new technologies, organizations should focus on user training and change management. A phased rollout allows teams to adapt gradually while providing feedback for continuous improvement. Clear communication about benefits and proper support resources are essential for successful adoption and long-term sustainability of technological initiatives.</p><p><strong>Future Outlook</strong></p><p>As digital transformation continues to accelerate, businesses must remain adaptable and open to emerging trends. Cloud computing, automation, and data-driven decision-making will play increasingly important roles in shaping competitive advantages. Organizations that embrace innovation while maintaining focus on user needs will be best positioned for future success.</p>").Render()
            @Html.EJS().InlineAIAssist("inline-ai-assist").PromptRequest("onRtePromptRequest").Created("onRtePromptCreated").Close("onInlinePromptClose").ResponseMode(Syncfusion.EJ2.InteractiveChat.ResponseMode.Inline).CommandSettings(new InlineAIAssistCommandSettings{ Commands = commandsData }).ResponseSettings(new InlineAIAssistResponseSettings { ItemSelect = "onRteResponseItemSelect" }).InlineToolbarSettings(new InlineAIAssistInlineToolbarSettings { ItemClick = "inlineItemClicked"}).Render()
        </div>
    </div>
}

<style>
    .e-inlineaiassist-selected-text {
        display: inline-block;
    }
</style>

@section PreScripts {
    <script>
    var rteSelection;
    var saveSelection;
    var range;
    var selectedText = '';
    var selectedSpan = null;
    var abortController;
    var rteEditor;
    var rtePrompt;
    var inlinePromptObj;
    var userId;
    var baseURL = window.baseurl;

    function created() {
        rteEditor = this;
        rteSelection = new ej.richtexteditor.NodeSelection();
    }

    function onRtePromptCreated() {
        var element = document.getElementById('inline-ai-assist');
        rtePrompt = ej.base.getComponent(element, 'inlineaiassist');
    }

    function toolbarClick(args) {
        if (args.item.prefixIcon === 'e-icons e-ai-chat') {
            range = rteSelection.getRange(document);
            var relateToEl = range.endContainer.parentElement;
            selectedText = rteEditor.getSelection();
            if (selectedText && selectedText.length > 0) {
                var wrapper = document.createElement('span');
                wrapper.className = 'e-inlineaiassist-selected-text';
                var selectedContent = range.extractContents();
                wrapper.appendChild(selectedContent);
                range.insertNode(wrapper);
                selectedSpan = wrapper;
                rtePrompt.relateTo = relateToEl ? relateToEl : wrapper;
                rtePrompt.dataBind();
                rtePrompt.showPopup();
            }
        }
    }

    function onInlinePromptClose() {
        if (selectedSpan) {
            rteEditor.formatter.saveData();
            selectedSpan = null;
            rteEditor.executeCommand('undo');
            rteEditor.clearUndoRedo();
            window.getSelection().removeAllRanges();
        }
    }

    function inlineItemClicked (args) {
        if (args.item.iconCss === 'e-icons e-inline-stop') {
            if (abortController) {
                abortController.abort();
            }
        }
    }

    function onRteResponseItemSelect(args) {
        if (args.command.label === 'Accept') {
            var response = rtePrompt.prompts[rtePrompt.prompts.length - 1].response.trim();
            if (selectedSpan && selectedSpan.parentNode) {
                var parent = selectedSpan.parentNode;
                parent.removeChild(selectedSpan);
                selectedSpan = null;
            }
            saveSelection = rteSelection.save(range, document);
            if (response && rteEditor) {
                saveSelection.restore();
                rteEditor.executeCommand('insertHTML', response);
                rteEditor.formatter.saveData();
                rteEditor.formatter.enableUndo(rteEditor);
            }
            rtePrompt.hidePopup();
        }
        else if (args.command.label === 'Discard') {
            if (selectedSpan && selectedSpan.parentNode) {
                var parent = selectedSpan.parentNode;
                var textNode = document.createTextNode(selectedText);
                parent.insertBefore(textNode, selectedSpan);
                parent.removeChild(selectedSpan);
                selectedSpan = null;
            }
            rtePrompt.hidePopup();
        }
    }

    function onRtePromptRequest(args) {
        setTimeout(function () {
            if (selectedSpan) {
                var fallbackResponse = 'We could not reach the AI service; please try again later.';
                selectedSpan.innerHTML = fallbackResponse;
                rtePrompt.addResponse(fallbackResponse);
                var newRange = document.createRange();
                newRange.selectNodeContents(selectedSpan);
                rteEditor.selectRange(newRange);
                range = rteSelection.getRange(document);
            }
        }, 1000);
    }
    </script>
}

@section Meta{
    <meta name="description" content="This example demonstrates the integration of the Inline AI Prompt component with the Syncfusion Rich Text Editor in ASP.NET MVC. Explore here for more details." />
}

@section ActionDescription{
    <div id="action-description">
        <p>This sample demonstrates the integration of the Inline AI Assist component with the Syncfusion Rich Text Editor. It showcases advanced customization including command settings, response settings, and inline response mode for enhanced content editing experience.</p>
    </div>
}

@section Description{
    <div id="description">
        <p>
            In this example, the Inline AI Assist component is seamlessly integrated with the Rich Text Editor, providing an advanced use-case scenario for AI-powered content creation and editing.
        </p>
        <p>
            <b>Key features demonstrated:</b>
        </p>
        <ul>
            <li><code>CommandSettings</code> - Custom AI command buttons (Improve, Shorten, Elaborate, Summarize, Simplify, Check Grammar) integrated into the interface</li>
            <li><code>ResponseSettings</code> - Configured response behavior with dynamic suggestion updates based on user actions</li>
            <li><code>ResponseMode</code> - Set to <code>'Inline'</code> mode where the AI response is directly streamed into the editor area, allowing users to see real-time content changes</li>
            <li><code>Accept/Reject</code> - Users can accept or reject the AI-generated suggestions</li>
        </ul>
    </div>
}

@section Header{
    <h1 class='sb-sample-text'>Inline AI Assist with Rich Text Editor</h1>
}

@section Title{
    <title>ASP.NET MVC Inline AI Assist with Rich Text Editor - Syncfusion Demos</title>
}
