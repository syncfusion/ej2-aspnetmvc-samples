@using Syncfusion.EJ2.Schedule
@using Syncfusion.EJ2.Charts
@using Syncfusion.EJ2.DropDowns
@section ActionDescription {
    <div id="action-description">
        <p>
            <strong>Fleet Management Dashboard:</strong>
            A modern timeline scheduler with real-time analytics visualization.
            Manage driver schedules and monitor fleet metrics through an integrated
            analytics dashboard.
        </p>
    </div>
}
@section ControlsSection {

    <div class="col-lg-12 schedule-with-chart control-section">
        <div class="content-wrapper">
            <div class="modern-layout" style="display:flex; gap:10px;">

                <!-- Scheduler Wrapper -->
                <div class="scheduler-wrapper">
                    @Html.EJS().Schedule("schedule").Width("100%").Height("650px").CssClass("schedule-with-chart").AllowOverlap(false).SelectedDate(new
                                DateTime(2026, 1, 12)).CurrentView(View.TimelineMonth).Views(view
                                =>
                                {
                                    view.Option(View.TimelineMonth).Add();
                                }).ResourceHeaderTemplate("#resourceTemplate").HeaderIndentTemplate("#headerIndentTemplate").Group(group
                                                => group.EnableCompactView(false).Resources(new string[] { "TruckDetails" }).HeaderTooltipTemplate("#tooltipTemplate")).Resources(res
                                                =>
                                                {
                                                    res.DataSource(ViewData["Drivers"]).Field("DriverID").Title("Drivers").Name("TruckDetails").TextField("driver").IdField("id").ColorField("color").Add();
                                                }).EventSettings(e
                                                => e.DataSource(ViewData["Events"])).ActionComplete("schedulerActionComplete").ActionBegin("onSchedulerActionBegin").DataBound("onSchedulerDataBound").Render()
                </div>

                <!-- Chart -->
                <div id="chart-container" class="chart-section">
                    <div class="chart-header">
                        <h4 class="chart-title">Analytics</h4>@Html.EJS().DropDownList("chart-ddl").DataSource(new
                                                                    List<object>{new { text="Trip Count", value="tripcount"},new { text="Truck Capacity",
                    value="capacity"},new { text="Longest Trips", value="longest"}}).Fields(new
                                                                    DropDownListFieldSettings
                    { Text = "text", Value = "value" }).Value("tripcount").Change("onDropDownChange").Render()
                    </div>
                    @Html.EJS().Chart("chart").Height("550px").Width("100%").Title("Trip Count").Load("load").PrimaryXAxis(px=>px.ValueType(Syncfusion.EJ2.Charts.ValueType.Category).Interval(1).LabelRotation(-45)).PrimaryYAxis(new Syncfusion.EJ2.Charts.ChartAxis{Title="Value"}).Series(series=>{series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Column).XName("Driver").YName("Value").DataSource(new List<object>{new { Driver="Init", Value=0 }}).ColumnSpacing(0.2).ColumnWidth(0.85).CornerRadius(cr=>cr.TopLeft(8).TopRight(8)).Add();}).Tooltip(tt=>tt.Enable(true).EnableHighlight(true)).ChartArea(ca=>ca.Border(br=>br.Width(0))).PointRender("onPointRender").Render()
                </div>

            </div>
        </div>
    </div>

    <!-- Templates -->
    <script id="resourceTemplate" type="text/x-template">
                    <div class="template-wrap">
                        <div>${resourceData.driver}</div>
                        <div>${resourceData.truck}</div>
                        <div>${resourceData.capacity}</div>
                    </div>
    </script>

    <script id="tooltipTemplate" type="text/x-template">
                    <div class="template-wrap">
                        <div>Name : ${resourceData.driver}</div>
                        <div>Truck : ${resourceData.truck}</div>
                        <div>Capacity : ${resourceData.capacity}</div>
                    </div>
    </script>

    <script id="headerIndentTemplate" type="text/x-template">
                    <div class="template-wrap header-indent">
                        <div>Driver</div>
                        <div>Truck</div>
                        <div>Capacity</div>
                    </div>
    </script>
	<script src="~/Scripts/chart/theme-color.js"></script>

    <script>
        let chart, ddl;
        let shouldUpdateChart = false;
		var load = function (args) {
            loadChartTheme(args);
        }
        window.addEventListener('load', function () {
            ej.schedule.Schedule.Inject(
                ej.schedule.TimelineMonth,
                ej.schedule.Resize,
                ej.schedule.DragAndDrop
            );
            chart = document.getElementById('chart').ej2_instances[0];
            ddl = document.getElementById('chart-ddl').ej2_instances[0];
            updateChart();
        });
        let mode = 'tripcount';
        const driversMaster = @Html.Raw(ViewData["Drivers"]);
        let events = @Html.Raw(ViewData["Events"]);
        function generateChartData(mode) {
            if (mode === 'capacity') {
                return driversMaster.map(d => ({
                    Driver: d.truck,
                    OriginalDriver: d.driver,
                    Value: parseFloat(d.capacity)
                }));
            }
            if (mode === 'tripcount') {
                const m = {};
                events.forEach(e => {
                    const n = driversMaster.find(d => d.id === e.DriverID)?.driver;
                    if (n) m[n] = (m[n] || 0) + 1;
                });
                return driversMaster.map(d => ({ Driver: d.driver, Value: m[d.driver] || 0 })).filter(d => d.Value > 0);
            }
            if (mode === 'longest') {
                const totals = {};
                events.forEach(e => {
                    const name = driversMaster.find(d => d.id === e.DriverID)?.driver;
                    if (!name || !e.StartTime || !e.EndTime) return;
                    const start = new Date(e.StartTime);
                    const end = new Date(e.EndTime);
                    const hours = (end - start) / 36e5;
                    if (!totals[name] || hours > totals[name]) {
                        totals[name] = hours;
                    }
                });
                return driversMaster
                    .map(d => ({
                        Driver: d.driver,
                        Value: totals[d.driver] ? Math.round(totals[d.driver] * 100) / 100 : 0
                    }))
                    .filter(d => d.Value > 0);
            }
            return [];
        }

        function updateChart() {
            if (!chart) return;
            chart.series[0].dataSource = generateChartData(mode);
            if (mode === 'tripcount') {
                chart.primaryYAxis = { title: 'Count', interval: 2 };
                chart.title = 'Trip Count';
            }
            else if (mode === 'capacity') {
                chart.primaryYAxis = { title: 'Capacity (t)', interval: null };
                chart.title = 'Truck Capacity';
            }
            else {
                chart.primaryYAxis = { title: 'Duration (hours)', interval: null };
                chart.title = 'Longest Trips';
            }
            chart.refresh();
        }
        function schedulerActionComplete(args) {
    if (
        args.requestType === 'eventCreated' ||
        args.requestType === 'eventChanged' ||
        args.requestType === 'eventRemoved'
    ) {
        const scheduleObj = document.getElementById('schedule').ej2_instances[0];

        events = scheduleObj.getEvents().map(e => ({
            DriverID: e.DriverID || e.driverID,
            StartTime: e.StartTime || e.startTime,
            EndTime: e.EndTime || e.endTime
        }));

        updateChart();
    }
}

        function onDropDownChange(e) {
            mode = e.value;
            updateChart();
        }

        function onPointRender(args) {
            let resource;
            if (mode === 'capacity') {
                resource = driversMaster.find(d => d.truck === args.point.x);
            } else {
                resource = driversMaster.find(d => d.driver === args.point.x);
            }
            if (resource) {
                args.fill = resource.color;
            }
        }

        function onSchedulerDataBound() {

    if (!shouldUpdateChart) return; 

    const scheduleObj = document.getElementById('schedule').ej2_instances[0];

    events = scheduleObj.getEvents().map(e => ({
        DriverID: e.DriverID || e.driverID,
        StartTime: e.StartTime || e.startTime,
        EndTime: e.EndTime || e.endTime
    }));

    updateChart();

    shouldUpdateChart = false; 
}

function onSchedulerActionBegin(args) {
    if (
        args.requestType === 'eventCreate' ||
        args.requestType === 'eventChange' ||
        args.requestType === 'eventRemove'
    ) {
        shouldUpdateChart = true; 
    }
}


    </script>


