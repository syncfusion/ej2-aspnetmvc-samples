@using Syncfusion.EJ2
@using Syncfusion.EJ2.Schedule

@section ControlsSection{
    <div class="control-section">
        <div class="content-wrapper">

            @Html.EJS().Schedule("schedule").Height("600px").CssClass("custom-scheduler").SelectedDate(new DateTime(2026, 5, 11)).CurrentView(View.TimelineDay).Views(v =>{v.Option(View.TimelineDay).Add();}).Group(group => group.Resources((string[])ViewData["ResourceNames"])).Resources(res =>{res.DataSource(ViewData["staffData"]).Field("StaffId").Title("Staff").Name("Staff").TextField("text").IdField("id").ColorField("color").Add();}).EventSettings(e => e.DataSource(ViewData["datasource"])).EditorTemplate("#EditorTemplate").ResourceHeaderTemplate("#resourceTemplate").HeaderIndentTemplate("#headerIndentTemplate").PopupOpen("onPopupOpen").PopupClose("onPopupClose").EventRendered("onEventRendered").Render()

        </div>
    </div>

    <script id="resourceTemplate" type="text/x-template">
        <div class="template-wrap">
            <div style="display:flex;gap:8px;align-items:center;">
                <div style="
                    width:32px;
                    height:32px;
                    border-radius:50%;
                    background:${resourceData.color};
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    color:#fff;">
                    ${resourceData.text[0]}
                </div>

                <div>${resourceData.text}</div>
            </div>

            <div>${resourceData.type}</div>
        </div>
    </script>
    <script id="headerIndentTemplate" type="text/x-template">
        <div class="template-wrap header-indent">
            <div>Staff</div>
            <div>Type</div>
        </div>
    </script>

    <script id="EditorTemplate" type="text/x-template">
        <table>
            <tr>
                <td>Name</td>
                <td><input class="e-field e-input" name="Subject" /></td>
            </tr>
            <tr>
                <td>Type</td>
                <td><input name="Type" class="e-field" /></td>
            </tr>
            <tr class="meeting-field" style="display:none;">
                <td>Floor</td>
                <td><input name="FloorId" class="e-field" /></td>
            </tr>
            <tr class="meeting-field" style="display:none;">
                <td>Room</td>
                <td><input name="RoomId" class="e-field" /></td>
            </tr>
            <tr>
                <td>Staff</td>
                <td><input name="StaffId" class="e-field" /></td>
            </tr>
            <tr>
                <td>Start</td>
                <td><input name="StartTime" class="e-field" /></td>
            </tr>
            <tr>
                <td>End</td>
                <td><input name="EndTime" class="e-field" /></td>
            </tr>
        </table>
    </script>

    <script type="text/javascript">

        var floors = [
            { id: 1, name: 'Floor 1' },
            { id: 2, name: 'Floor 2' }
        ];

        var rooms = [
            { id: 101, name: 'Room 101', floorId: 1 },
            { id: 102, name: 'Room 102', floorId: 1 },
            { id: 201, name: 'Room 201', floorId: 2 },
            { id: 202, name: 'Room 202', floorId: 2 }
        ];

        var typeOptions = ['Meeting', 'Appointment', 'Internal'];

        var staffData = @Html.Raw(Json.Encode(ViewData["staffData"]));

        function onPopupOpen(args) {
            if (args.type !== 'Editor') return;
            args.element.classList.add('cascading-editor-dialog')

            var data = args.data;

            var typeValue = data.Type || 'Meeting';
            var floorValue = data.FloorId || null;
            var roomValue = data.RoomId || null;

            function getField(name) {
                var fields = args.element.querySelectorAll('.e-field');
                for (var i = 0; i < fields.length; i++) {
                    if (fields[i].name === name) return fields[i];
                }
                return null;
            }

            var typeEl = getField('Type');
            var floorEl = getField('FloorId');
            var roomEl = getField('RoomId');
            var staffEl = getField('StaffId');
            var startEl = getField('StartTime');
            var endEl = getField('EndTime');

            var typeObj = new ej.dropdowns.DropDownList({
                dataSource: typeOptions,
                value: typeValue,
                change: onTypeChange
            });
            typeObj.appendTo(typeEl);

            var floorObj = new ej.dropdowns.DropDownList({
                dataSource: floors,
                fields: { text: 'name', value: 'id' },
                value: floorValue,
                change: onFloorChange
            });
            floorObj.appendTo(floorEl);

            var roomObj = new ej.dropdowns.DropDownList({
                dataSource: [],
                fields: { text: 'name', value: 'id' },
                value: roomValue
            });
            roomObj.appendTo(roomEl);

            new ej.dropdowns.DropDownList({
                dataSource: staffData,
                fields: { text: 'text', value: 'id' },
                value: data.StaffId || null
            }).appendTo(staffEl);

            new ej.calendars.DateTimePicker({ value: data.StartTime }).appendTo(startEl);
            new ej.calendars.DateTimePicker({ value: data.EndTime }).appendTo(endEl);

            toggleMeeting(typeValue === 'Meeting');

            if (typeValue === 'Meeting') {
                var filteredRooms = floorValue
                    ? rooms.filter(r => r.floorId === floorValue)
                    : [];

                roomObj.dataSource = filteredRooms;
                roomObj.dataBind();
            }

            function onTypeChange(e) {
                floorObj.value = null;
                roomObj.value = null;
                roomObj.dataSource = [];
                roomObj.dataBind();
                toggleMeeting(e.value === 'Meeting');
            }

            function onFloorChange(e) {
                var filtered = rooms.filter(r => r.floorId === e.value);

                roomObj.dataSource = filtered;
                roomObj.dataBind();
                roomObj.value = null;
            }

            function toggleMeeting(show) {
                var rows = args.element.querySelectorAll('.meeting-field');
                rows.forEach(row => row.style.display = show ? '' : 'none');
            }
        }

        function onPopupClose(args) { }

        function onEventRendered(args) {
            var type = args.data.Type || "Meeting";
            var color = "#6b7280";

            if (type === "Meeting") color = "#22c55e";
            if (type === "Appointment") color = "#3b82f6";
            if (type === "Internal") color = "#f59e0b";

            args.element.style.backgroundColor = color;
        }

    </script>

