@using Syncfusion.EJ2
@using Syncfusion.EJ2.Schedule

@section ControlsSection{
    <div class="control-section">
        <div class="content-wrapper">
            @Html.EJS().Schedule("Schedule").Width("100%").Height("650px").CssClass("event-action-buttons").SelectedDate(new DateTime(DateTime.Today.Year, 2, 16)).PopupOpen("onPopupOpen").EventRendered("onEventRendered").Views(view => { view.Option(View.Day).Add(); view.Option(View.Week).Add(); }).EventSettings(new ScheduleEventSettings { DataSource = ViewData["datasource"], Template = "#event-template" }).Render()
        </div>
    </div>

    <style>
        .event-action-buttons.e-schedule .custom-event {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 100%;
            padding: 2px 4px;
            overflow: hidden;
            width: 100%;
        }

        .event-action-buttons.e-schedule .event-subject {
            flex: 1;
            display: flex;
            align-items: center;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .event-action-buttons.e-schedule .event-title {
            font-size: 12px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .event-action-buttons.e-schedule .event-time {
            font-size: 12px;
            text-wrap: auto;
        }

        .event-action-buttons.e-schedule .event-actions {
            display: flex;
            gap: 4px;
            padding: 4px;
        }

        .event-action-buttons.e-schedule .icon-btn {
            background: transparent;
            border: none;
            padding: 2px;
            cursor: pointer;
        }

        .event-action-buttons.e-schedule .icon-btn .e-icons {
            font-size: 12px;
        }

        .event-action-buttons.e-schedule .e-vertical-view .e-all-day-appointment-wrapper .event-time {
            display: none;
        }

        @@media (max-width: 768px) {
            .event-action-buttons.e-schedule .e-week-view .event-title {
                font-size: 10px;
            }

            .event-action-buttons.e-schedule .e-week-view .icon-btn .e-icons {
                font-size: 10px;
            }

            .event-action-buttons.e-schedule .e-week-view .event-time {
                font-size: 10px;
            }

            .event-action-buttons.e-schedule .e-week-view .event-actions {
                gap: 2px;
                padding: 0px;
            }

            .event-action-buttons.e-schedule .e-week-view .custom-event {
                display: contents;
            }
        }
    </style>

    <script src="~/Scripts/schedule/applyCategoryColor.js"></script>

    <script id="event-template" type="text/x-template">
        <div class="custom-event">
            <div class="event-subject">
                <div class="event-title">${Subject}</div>
            </div>
            <div class="event-actions">
                <button class="icon-btn edit-btn">
                    <span class="e-icons e-edit"></span>
                </button>
                <button class="icon-btn delete-btn">
                    <span class="e-icons e-trash"></span>
                </button>
            </div>
        </div>
        <div class="event-time">
            Time: ${getTimeString(data.StartTime)} - ${getTimeString(data.EndTime)}
        </div>
    </script>

    <script>
        var instance = new ej.base.Internationalization();

        function getTimeString(value) {
            return instance.formatDate(value, { format: 'HH:mm' });
        };

        function onPopupOpen(args) {
            if (args.type === 'QuickInfo' && args.data && args.data.Id > 0) {
                args.cancel = true;
            }

            if (args.type === 'Editor') {
                var dialog = args.element.closest('.e-dialog');
                if (dialog) {
                    var elementsToHide = dialog.querySelectorAll('.e-repeat-parent-row, .e-recurrenceeditor');
                    elementsToHide.forEach(function (el) {
                        el.style.display = 'none';
                    });
                }
            }
        }

        function onEventRendered(args) {
            var scheduleObj = document.getElementById('Schedule').ej2_instances[0];

            applyCategoryColor(args, scheduleObj.currentView);

            var eventData = args.data;

            var editBtn = args.element.querySelector('.edit-btn');
            var deleteBtn = args.element.querySelector('.delete-btn');

            if (editBtn) {
                editBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    scheduleObj.openEditor(eventData, 'Save');
                });
            }

            if (deleteBtn) {
                deleteBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    scheduleObj.deleteEvent(eventData);
                });
            }
        }
    </script>
}

@section ActionDescription{
    <div id="action-description">
        <p>
            This demo showcases the event action buttons for editing and deleting events in day and week views. Click the edit or delete icons to manage your events.
        </p>
    </div>
}

@section Description{
    <div id="description">
        <p>
            In this demo, we have implemented custom event templates with action buttons for each event displayed in the Scheduler. These action buttons allow users to edit or delete events directly from the event cells. When the Edit button is clicked, the event editor is opened using the <code>openEditor</code> method. When the Delete button is clicked, the selected event is removed using the <code>deleteEvent</code> method.
        </p>
        <p>
            Looking for the full ASP.NET MVC Scheduler component overview, features, pricing, and documentation? Visit our <a target="_blank" href="https://www.syncfusion.com/aspnet-mvc-ui-controls/scheduler" aria-label="Navigate to the ASP.NET MVC Scheduler FT page">ASP.NET MVC Scheduler</a> page.
        </p>
    </div>
}

@section Title{
    <title>ASP.NET MVC Scheduler Event Action Buttons</title>
}

@section Header{
    <h1 class='sb-sample-text'>Example of Event Action Buttons in ASP.NET MVC Scheduler Control</h1>
}