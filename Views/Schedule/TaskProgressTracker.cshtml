
@using Syncfusion.EJ2.Schedule
@using EJ2MVCSampleBrowser.Models
@using Newtonsoft.Json

@{
    var employeeData = new List<object>() {
        new { Text = "Sarah", Id = 1, Color = "#EF4444" },
        new { Text = "John", Id = 2, Color = "#10B981" },
        new { Text = "Emma", Id = 3, Color = "#3B82F6" },
        new { Text = "Michael", Id = 4, Color = "#F59E0B" },
        new { Text = "Lisa", Id = 5, Color = "#8B5CF6" },
        new { Text = "David", Id = 6, Color = "#EC4899" }
    };
    var resourceNames = new string[] { "Employees" };
    var taskData = new ScheduleEvents().GetTaskData();
}

@section ControlsSection{

<div class="col-lg-12 control-section">
    <div class="content-wrapper">
        @Html.EJS().Schedule("Schedule").CssClass("event-customization-schedule").Width("100%").Height("550px").SelectedDate(new DateTime(2026, 4, 24)).CurrentView(View.TimelineWeek).PopupOpen("onPopupOpen").EventRendered("onEventRendered").AllowOverlap(false).StartHour("09:00").EndHour("18:00").ShowWeekend(false).Views(view => { view.Option(View.TimelineWeek).Add(); }).Group(group => group.EnableCompactView(false).Resources(resourceNames)).Resources(res => { res.Field("EmployeeId").Name("Employees").DataSource(employeeData).TextField("Text").IdField("Id").ColorField("Color").Add(); }).EventSettings(e => { e.DataSource(taskData).Template("#eventTemplate").Fields(f => { f.Id("Id"); f.Subject(s => s.Name("Subject")); f.StartTime(st => st.Name("StartTime")); f.EndTime(et => et.Name("EndTime")); f.Description(d => d.Name("Description")); }); }).Render()
    </div>
</div>

<script id="eventTemplate" type="text/x-template">
    <div class="custom-event e-${Status}" title="${Subject}">
        <div class="event-header">
            <div class="event-subject">${Subject}</div>
            <div class="event-progress-percent">${Progress}%</div>
        </div>

        <div class="event-footer">
            <div class="label-wrapper">
                <span class="e-icons ${Status}-icon status-icon"></span>
                <span class="status-label">${Status}</span>
            </div>
        </div>
    </div>
</script>

<script>

    var STATUS_MAP = {
        'pending': { icon: 'e-clock', color: '#DC2626' },
        'in-progress': { icon: 'e-play', color: '#3B82F6' },
        'review': { icon: 'e-eye', color: '#F59E0B' },
        'done': { icon: 'e-check', color: '#10B981' }
    };

    function onPopupOpen(args) {
        if (args.type !== 'Editor') return;

        var dialog = args.element.closest('.e-dialog');
        if (dialog) {
            var elementsToHide = dialog.querySelectorAll('.e-repeat-parent-row, .e-recurrenceeditor');
            elementsToHide.forEach(function (el) {
                el.style.display = 'none';
            });
        }

        var form = args.element.querySelector('.e-schedule-form');
        if (!form) return;

        var existingCustomFields = form.querySelector('.custom-fields');
        if (existingCustomFields) {
            existingCustomFields.remove();
        }

        var container = document.createElement('div');
        container.className = 'custom-fields';

        container.innerHTML = [
            '<div class="e-field-group e-custom-row">',
                '<input id="statusDropdown" name="Status" type="text" class="e-field" />',
            '</div>',

            '<div class="e-field-group e-custom-row">',
                '<div class="e-float-input e-control-wrapper e-input-group">',
                    '<input id="progressInput"',
                        ' name="Progress"',
                        ' type="number"',
                        ' min="0"',
                        ' max="100"',
                        ' step="1"',
                        ' class="e-field e-input"',
                        ' value="', (args.data.Progress || '0'), '" />',
                    '<label class="e-float-text e-label-top">Progress (%)</label>',
                '</div>',
            '</div>'
        ].join('');

        form.appendChild(container);

        var progressEl = container.querySelector('[name="Progress"]');

        var statusDropdown = new ej.dropdowns.DropDownList({
            dataSource: [
                { text: 'Pending', value: 'pending' },
                { text: 'In-Progress', value: 'in-progress' },
                { text: 'Review', value: 'review' },
                { text: 'Done', value: 'done' }
            ],
            fields: { text: 'text', value: 'value' },
            value: args.data.Status || 'pending',
            change: function (e) {
                applyStatusRules(e.value);
            },
            placeholder: 'Status',
            floatLabelType: 'Auto'
        });
        statusDropdown.appendTo('#statusDropdown');

        progressEl.value = (args.data.Progress !== undefined && args.data.Progress !== null) ? args.data.Progress : 0;

        args.data.Status = args.data.Status || 'pending';
        args.data.Progress = args.data.Progress != null ? args.data.Progress : 0;

        applyStatusRules(statusDropdown.value);

        progressEl.addEventListener('input', function (e) {
            var value = Number(e.target.value) || 0;
            var currentStatus = statusDropdown.value;

            if (currentStatus === 'in-progress') {
                if (value >= 99) value = 98;
                if (value <= 0) value = 0;
            }

            e.target.value = value;
        });

        function applyStatusRules(status) {
            if (status === 'done') {
                progressEl.value = 100;
                progressEl.disabled = true;
            } else if (status === 'review') {
                progressEl.value = 99;
                progressEl.disabled = true;
            } else if (status === 'pending') {
                progressEl.value = 0;
                progressEl.disabled = true;
            } else if (status === 'in-progress') {
                var currentValue = Number(progressEl.value) || 0;
                if (currentValue >= 99) {
                    progressEl.value = 98;
                }
                progressEl.disabled = false;
            } else {
                progressEl.disabled = false;
            }
        }
    }
    
    function onEventRendered(args) {
        var data = args.data;
        var element = args.element;

        var status = data.Status || 'pending';
        var progress = data.Progress != null ? data.Progress : 0;

        var config = STATUS_MAP[status];

        if (args.resourceData && args.resourceData.Color) {
            element.style.borderLeft = '4px solid ' + args.resourceData.Color;
        }

        var subjectEl = element.querySelector('.event-subject');
        if (subjectEl && !data.Subject) {
            subjectEl.innerText = 'Task';
        }

        var progressEl = element.querySelector('.event-progress-percent');
        if (progressEl) {
            progressEl.innerText = progress + '%';
        }

        var labelWrapper = element.querySelector('.label-wrapper');
        if (labelWrapper) {
            labelWrapper.innerHTML = '';

            labelWrapper.style.backgroundColor = config.color;

            var icon = document.createElement('span');
            icon.className = 'e-icons ' + config.icon + ' status-icon';

            var text = document.createElement('span');
            text.className = 'status-label';
            text.innerText = status;

            labelWrapper.appendChild(icon);
            labelWrapper.appendChild(text); 
        }
    }

    function onActionBegin(args) {
        if (args.requestType === 'eventCreate' || args.requestType === 'eventChange') {
            var data = args.requestType === 'eventCreate' ? args.data[0] : args.data;

            data.Status = data.Status || "pending";
            data.Progress = data.Progress != null ? data.Progress : 0;
        }
    }

</script>

<style>
    .event-customization-schedule.e-schedule .e-appointment .e-appointment-details {
        height: 100%;
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
        display: flex;
    }


    .event-customization-schedule.e-schedule .e-event-resize.e-right-handler {
        background: #F3F4F6;
    }

    .event-customization-schedule.e-schedule .custom-event {
        background: #F3F4F6;
        height: 100%;
        width: 100%;
        box-shadow: none;
        padding: 2px 8px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        overflow: hidden;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .event-customization-schedule.e-schedule .custom-event .event-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 4px;
        width: 100%;
        padding: 1px 0;
    }

    .event-customization-schedule.e-schedule .custom-event .event-header .event-subject {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 11px;
        font-weight: 600;
        color: #1F2937;
        line-height: 1.1;
    }

    .event-customization-schedule.e-schedule .custom-event .event-header .event-progress-percent {
        background: rgba(0, 0, 0, 0.5);
        padding: 1px 4px;
        border-radius: 2px;
        color: #fff;
        font-weight: 700;
        font-size: 9px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .event-customization-schedule.e-schedule .custom-event .event-footer {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 3px;
        width: 100%;
        line-height: 1;
        padding: 1px 0;
    }

    .event-customization-schedule.e-schedule .custom-event .event-footer .label-wrapper{
        color: #ffffff;
        background-color: var(--status-color, #DC2626);
        padding: 2px 4px;
        border-radius: 2px;
        display: flex;
        align-items: center;
        gap: 2px;
        font-size: 8px;
        font-weight: 500;
    }

    .event-customization-schedule.e-schedule .custom-event .event-footer .label-wrapper .status-label {
        text-transform: capitalize;
        letter-spacing: 0.5px;
    }

    .event-customization-schedule.e-schedule .e-timeline-view .e-resource-left-td {
        width: 150px;
    }

    .event-customization-schedule.e-schedule .e-timeline-view .e-date-header-wrap table col,
    .event-customization-schedule.e-schedule .e-timeline-view .e-content-wrap table col {
        width: 90px;
    }

    .event-customization-schedule.e-schedule .e-field-group.e-custom-row {
        margin-top: 16px;
    }
</style>
}

@section ActionDescription{
    <div id="action-description">
        <p>This demo showcases an advanced task progress tracker in the Scheduler with elegant event customization, vibrant status indicators, real-time progress visualization, and interactive editing. Track and manage team task assignments with visual status icons and completion percentage indicators.</p>
    </div>
}
@section Description{
    <div id="description">
        <p>
            The Task Progress Tracker displays team tasks with a refined visual design. Each event shows the task subject on the left and completion percentage on the right, while the status indicator icon is positioned at the bottom left with a colored background matching the task status.
        </p>
        <p><b>Status Tracking</b></p>
        <p>
            Tasks are displayed with visual status indicators: clock icon for pending tasks, play icon for in-progress work, eye icon for tasks under review, and checkmark icon for completed tasks. Each status has a distinct color for quick visual identification.
        </p>
        <p><b>Progress Visualization</b></p>
        <p>
            Each event displays the completion percentage in real-time. The progress indicator updates dynamically as tasks advance through different status states.
        </p>
        <p><b>Interactive Editing</b></p>
        <p>
            Edit task details directly from the Scheduler using the editor. Customize task status and progress percentage with automatic validation rules ensuring data consistency based on the selected status.
        </p>
        <p>Looking for the full ASP.NET MVC Scheduler component overview, features, pricing, and documentation? Visit our <a href="https://www.syncfusion.com/aspnet-mvc-ui-controls/scheduler" target="_blank">ASP.NET MVC Scheduler</a> page.</p>
    </div>
}
@section Title{
                    <title>ASP.NET MVC Scheduler Task Progress Tracker Example - Syncfusion Demos </title> 
                }
@section Header{
                    <h1 class='sb-sample-text'>Example of Task Progress Tracker in ASP.NET MVC Scheduler Control</h1>
                }