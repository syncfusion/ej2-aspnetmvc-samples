@using Syncfusion.EJ2;
@section ControlsSection{
    <div class="control-section" align="center">
            @{
                var gradient = new Syncfusion.EJ2.Charts.ChartLinearGradient
                {
                    X1 = 0,
                    Y1 = 0,
                    X2 = 1,
                    Y2 = 0,
                    GradientColorStop = new List<Syncfusion.EJ2.Charts.ChartGradientColorStop>
                    {
                        new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#1a9fd4", Offset = 0, Opacity = 1 },
                        new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#9b4dca", Offset = 50, Opacity = 1 },
                        new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#f95d8f", Offset = 100, Opacity = 1 }
                    }
                };
            }
       
            @Html.EJS().Chart("container").Series(
                series => {
                    series.Type(Syncfusion.EJ2.Charts.ChartSeriesType.Bar)
                     .Name("Revenue")
                     .XName("Company")
                     .YName("Revenue")
                     .DataSource(ViewData["ChartPoints"])
                     .ColumnSpacing(0.25)
                     .ColumnWidth(0.75)
                     .CornerRadius(cr => cr.TopRight(10).TopLeft(10).BottomRight(10).BottomLeft(10))
                     .LegendShape(Syncfusion.EJ2.Charts.LegendShape.Rectangle)
                     .Marker(m => m.Visible(false).DataLabel(dl => dl.Visible(true).Position(Syncfusion.EJ2.Charts.LabelPosition.Outer).Format("{value} B")))
                     .LinearGradient(gradient).Add();
                }).PrimaryXAxis(px => px.ValueType(Syncfusion.EJ2.Charts.ValueType.Category)
                    .MajorGridLines(mg => mg.Width(1)).MajorTickLines(mt => mt.Width(0)).LineStyle(ls => ls.Width(0))
                    .EdgeLabelPlacement(Syncfusion.EJ2.Charts.EdgeLabelPlacement.Shift)
                    .EnableWrap(true)
                    .MaximumLabelWidth(100)
            ).PrimaryYAxis(py => py.Visible(false)
            ).Tooltip(tooltip => tooltip.Enable(true).Header("").Format("${point.x}: <b>${point.y} B</b>")
            ).ChartArea(area => area.Border(br => br.Width(0))
            ).Title("Leading Revenue Drivers in India: 2024 Rankings"
            ).SubTitle("Source: Wikipedia (Forbes 2024) | Revenue in USD Billions"
            ).LegendSettings(leg => leg.Visible(false)
            ).ChartArea(area => area.Border(br => br.Width(0))).Load("load").Render()      
       
        </div>
   
@*custom code start*@
    <style>
        #control-container {
            padding: 0px !important;
        }
    </style>
@*custom code end*@
    <script src="~/Scripts/chart/theme-color.js"></script>
    <script>
        var load = function (args) {
            loadChartTheme(args);
            args.chart.width = ej.base.Browser.isDevice ? "100%" : "90%";
        }
    </script>
}
@*custom code start*@
@section Meta{
                    <meta name="description" content="This example demonstrates the Bar in ASP.NET MVC Chart control. Explore here for more details."/>
                }
@*custom code end*@
@section ActionDescription{
    <p>
        This <a target="_blank" href="https://www.syncfusion.com/aspnet-mvc-ui-controls/charts/chart-types/bar-chart" aria-label="ASP.NET MVC Bar Chart">ASP.NET MVC Bar Chart<span class="sr-only">opens in a new tab</span></a> example visualizes the top revenue-generating companies in India for 2024. A horizontal bar chart with a left-to-right color gradient 
        is used to highlight each company's revenue in USD Billions. Company names appear on the left axis, and revenue values are displayed at the 
        end of each bar. Companies are ordered by revenue to emphasize ranking and relative contribution. Compare bar lengths to quickly identify the top 
        contributors among India's leading corporations.
    </p>
}
@section Description{
    <p>
        In this example, you can see how to render and configure a horizontal bar chart with a linear gradient fill using the
        <code>LinearGradient</code> property of the series. The gradient is applied horizontally from left to right with multiple color stops
        to create smooth color transitions across all bars, visually emphasizing the revenue comparison.
    </p>
    <p>
        <code>Tooltip</code> is enabled in this example. To see the tooltip in action, hover over a bar or tap on a
        bar on touch-enabled devices.
    </p>
    <p>
        More information about the bar series can be found in this
        <a target="_blank" href="https://ej2.syncfusion.com/aspnetmvc/documentation/chart/chart-types/bar" aria-label="documentation section" >documentation section<span class="sr-only">opens in a new tab</span></a>.
    </p>
}
@section Title{
                    <title>ASP.NET MVC Chart Bar Example - Syncfusion Demos </title>
                }
@section Header{
                    <h1 class='sb-sample-text'>Charts</h1>
                }